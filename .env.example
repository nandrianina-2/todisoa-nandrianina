# Connexion à ta base MongoDB (Atlas ou locale)
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/portfolio"

# Identifiants de connexion admin (page /admin)
ADMIN_EMAIL="toi@example.com"
# Génère ce hash avec : node -e "console.log(require('bcryptjs').hashSync('ton-mot-de-passe', 10))"
ADMIN_PASSWORD_HASH="$2a$10$..."

# Requis par NextAuth v5 - génère avec : npx auth secret
AUTH_SECRET="remplace-moi-par-une-valeur-aleatoire"
